{
  "name": "openminions-builder",
  "displayName": "Openminions Visual Squad Builder",
  "description": "Visual drag-and-drop tool to construct Openminions squad.json pipelines",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openminions.startBuilder",
        "title": "Openminions: Start Visual Squad Builder"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run build:webview",
    "watch": "tsc -watch -p ./",
    "build:webview": "esbuild src/webview/BuilderApp.tsx --bundle --outfile=out/webview.js"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
